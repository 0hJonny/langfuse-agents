# Порт, на котором запустится сам API Gateway
PORT=8080

# Адрес gRPC-сервиса авторизации (нужен для валидации токенов на шлюзе)
AUTH_GRPC_ADDR=localhost:50051
# Для Docker-окружения замените на: AUTH_GRPC_ADDR=auth-service:50051

# HTTP Апстримы для проксирования запросов от шлюза к микросервисам
AUTH_HTTP_ADDR=http://localhost:8081
# Для Docker: AUTH_HTTP_ADDR=http://auth-service:8081

AGENTS_HTTP_ADDR=http://localhost:8082
# Для Docker: AGENTS_HTTP_ADDR=http://agents-service:8082

CHATS_HTTP_ADDR=http://localhost:8083
# Для Docker: CHATS_HTTP_ADDR=http://chats-service:8083

# Разрешенные источники для CORS (через запятую, без пробелов)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Конфигурация кэша Redis (для будущих сессий / рейт-лимитера)
REDIS_ADDR=localhost:6379
# Для Docker: REDIS_ADDR=redis:6379
